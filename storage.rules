rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Default deny-all ─────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ── Ride screenshots ─────────────────────────────────────────────
    // Authenticated users may read and write only within their own
    // ride-screenshots/{uid}/ prefix. Writes are restricted to image
    // types and a 10 MB size limit.
    match /ride-screenshots/{userId}/{fileName} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size <= 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
