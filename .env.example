# ─────────────────────────────────────────────────
# Trail Brew — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────

# OpenWeather API (required for live weather on trail cards)
# Free tier: 1 000 calls/day — sign up at https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# ─────────────────────────────────────────────────
# Firebase Configuration
# ─────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=trail-brew-33084.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=trail-brew-33084
VITE_FIREBASE_STORAGE_BUCKET=trail-brew-33084.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
