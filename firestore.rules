rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Global deny-all fallback ──────────────────────────────────────
    // Any path not explicitly matched below is denied. Firestore already
    // denies by default, but being explicit prevents accidental exposure
    // if new collections are added before rules are written for them.
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Trails (public catalogue) ─────────────────────────────────────
    // Anyone can browse trails; only callers with the `admin` custom claim
    // (set server-side via Firebase Admin SDK) can create, update, or delete.
    match /trails/{trailId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── User profiles ─────────────────────────────────────────────────
    // A user may only read or write their own document. Writes are
    // validated to prevent storing arbitrary or privileged fields.
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId) && validUserProfile();
      allow update: if isOwner(userId) && validUserProfile();
      allow delete: if isOwner(userId);

      // ── Service history subcollection ─────────────────────────────
      match /serviceHistory/{recordId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // ── Repair history subcollection ──────────────────────────────
      match /repairHistory/{recordId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // ── Ride logs subcollection ───────────────────────────────────
      // Ride logs are private to the owning user. Both required and optional
      // fields are validated on write.
      match /rides/{rideId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && validRideLog();
        allow update: if isOwner(userId) && validRideLog();
        allow delete: if isOwner(userId);
      }
    }

    // ── Helper functions ──────────────────────────────────────────────

    // True when the caller holds an `admin` custom claim set via Admin SDK.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // True when the caller is authenticated and owns the document path.
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Validates user-profile writes — only known fields are permitted so
    // arbitrary data cannot be stored in user documents.
    function validUserProfile() {
      let allowed = ['displayName', 'email', 'photoURL', 'lastSeen',
                     'riddenTrails', 'notes', 'preferences', 'createdAt',
                     'bikeData', 'stravaConnection'];
      return request.resource.data.keys().hasOnly(allowed);
    }

    // Validates ride-log writes — trailId, trailName, date, verificationMethod,
    // and loggedAt are required; no fields outside the allowed set are accepted.
    function validRideLog() {
      let required = ['trailId', 'trailName', 'date', 'verificationMethod', 'loggedAt'];
      let allowed  = ['trailId', 'trailName', 'date', 'distanceKm', 'durationMinutes',
                      'elevationM', 'note', 'verificationMethod', 'screenshotStoragePath',
                      'aiRawExtraction', 'aiConfidence', 'loggedAt'];
      return request.resource.data.keys().hasAll(required)
          && request.resource.data.keys().hasOnly(allowed);
    }
  }
}
